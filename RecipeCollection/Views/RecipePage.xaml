<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeCollection.Views.RecipePage"
             Title="RecipePage">

	<Grid RowSpacing="30"
		  Padding="25">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<Label Grid.Row="0"
			   HorizontalOptions="Center"
			   VerticalOptions="Center"
			   Text="Recipe"
			   FontSize="30"
			   FontAttributes="Bold"
			   TextColor="{StaticResource Orange}" />

		<Grid Grid.Row="1">
			<Button Command="{Binding TapReturnCommand}"
					BackgroundColor="{StaticResource Orange}"
					Text="Back"
					FontSize="18"
					FontAttributes="Bold"
					TextColor="{StaticResource EggWhite}">
			</Button>
		</Grid>
	</Grid>
</ContentPage>