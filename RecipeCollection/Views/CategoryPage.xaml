<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeCollection.Views.CategoryPage"
			 Title="Category Page"
			 xmlns:viewmodel="clr-namespace:RecipeCollection.ViewModels"
			 x:DataType="viewmodel:CategoryPageViewModel">

	<Grid RowSpacing="30"
		  Padding="25">
		<Grid.RowDefinitions>
			<RowDefinition Height="0.25*" />
			<RowDefinition Height="*" />
			<RowDefinition Height="0.25*" />
		</Grid.RowDefinitions>

		<Grid Grid.Row="0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="0.25*" />
				<ColumnDefinition Width="0.5*" />
				<ColumnDefinition Width="0.25*" />
			</Grid.ColumnDefinitions>

			<Button Grid.Column="0"
					Command="{Binding TapReturnCommand}"
					BackgroundColor="{StaticResource Orange}"
					Text="Back"
					FontSize="18"
					FontAttributes="Bold"
					TextColor="{StaticResource EggWhite}">
			</Button>

			<Label Grid.Column="1"
				   HorizontalOptions="Center"
				   VerticalOptions="Center"
				   Text="{Binding CategoryTitle}"
				   FontSize="30"
				   FontAttributes="Bold"
				   TextColor="{StaticResource Orange}" />
		</Grid>
		
		<CollectionView Grid.Row="1"
						ItemsSource="{Binding Recipes}">
			<CollectionView.ItemTemplate>
				<DataTemplate x:DataType="{x:Type x:String}">
					<Grid Padding="15">
						<Button Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:CategoryPageViewModel}}, Path=TapRecipeCommand}"
								CommandParameter="{Binding .}"
								BackgroundColor="{StaticResource Orange}"
								Text="{Binding .}"
								FontSize="18"
								FontAttributes="Bold"
								TextColor="{StaticResource EggWhite}">
						</Button>
					</Grid>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

		<Grid Grid.Row="2"
			  ColumnSpacing="20">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="0.7*" />
				<ColumnDefinition Width="0.15*" />
				<ColumnDefinition Width="0.15*" />
			</Grid.ColumnDefinitions>

			<Entry Grid.Column="0"
				   Placeholder="Enter Category..."
				   PlaceholderColor="{StaticResource Gray600}"
				   Text="{Binding RecipeToAdd}"
				   FontSize="18"
				   TextColor="{StaticResource Gray600}" />

			<Button Grid.Column="1"
					Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:CategoryPageViewModel}}, Path=AddRecipeCommand}"
					BackgroundColor="{StaticResource Orange}"
					Text="Add"
					FontSize="18"
					FontAttributes="Bold"
					TextColor="{StaticResource EggWhite}" />

			<Button Grid.Column="2"
					Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:CategoryPageViewModel}}, Path=RemoveRecipeCommand}"
					BackgroundColor="{StaticResource Orange}"
					Text="Remove"
					FontSize="18"
					FontAttributes="Bold"
					TextColor="{StaticResource EggWhite}" />
		</Grid>
	</Grid>
</ContentPage>