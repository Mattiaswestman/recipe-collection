<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 x:Class="RecipeCollection.Views.MainPage"
			 xmlns:viewmodel="clr-namespace:RecipeCollection.ViewModels"
			 x:DataType="viewmodel:MainPageViewModel">

	<Grid RowSpacing="30"
		  Padding="25">
		<Grid.RowDefinitions>
			<RowDefinition Height="0.25*" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<Label Grid.Row="0"
			   HorizontalOptions="Center"
			   VerticalOptions="Center"
			   Text="Recipe Collection"
			   FontSize="30"
			   FontAttributes="Bold"
			   TextColor="{StaticResource Orange}" />

		<CollectionView Grid.Row="1"
						ItemsSource="{Binding Categories}">
			<CollectionView.ItemTemplate>
				<DataTemplate x:DataType="{x:Type x:String}">
					<Grid Padding="15">
						<Button Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainPageViewModel}}, Path=TapCategoryCommand}"
								BackgroundColor="{StaticResource Orange}"
								Text="{Binding .}"
								FontSize="18"
								FontAttributes="Bold"
								TextColor="{StaticResource EggWhite}">
						</Button>
					</Grid>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>
	</Grid>
</ContentPage>