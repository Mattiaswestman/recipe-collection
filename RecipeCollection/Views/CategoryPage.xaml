<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeCollection.Views.CategoryPage"
             Title="CategoryPage">

	<Grid RowSpacing="30"
		  Padding="25">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<Label Grid.Row="0"
			   HorizontalOptions="Center"
			   VerticalOptions="Center"
			   Text="Category"
			   FontSize="30"
			   FontAttributes="Bold"
			   TextColor="{StaticResource Orange}" />

		<Grid Grid.Row="1"
			  RowSpacing="15">
			<Grid.RowDefinitions>
				<RowDefinition Height="0.5*" />
				<RowDefinition Height="0.5*" />
			</Grid.RowDefinitions>

			<Button Grid.Row="0"
					Command="{Binding TapRecipeCommand}"
					BackgroundColor="{StaticResource Orange}"
					Text="Recipe"
					FontSize="18"
					FontAttributes="Bold"
					TextColor="{StaticResource EggWhite}">
			</Button>

			<Button Grid.Row="1"
					Command="{Binding TapReturnCommand}"
					BackgroundColor="{StaticResource Orange}"
					Text="Back"
					FontSize="18"
					FontAttributes="Bold"
					TextColor="{StaticResource EggWhite}">
			</Button>
		</Grid>
	</Grid>
</ContentPage>