<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeCollection.Views.RecipePage"
			 Title="Recipe Page"
			 xmlns:viewmodel="clr-namespace:RecipeCollection.ViewModels"
			 x:DataType="viewmodel:RecipePageViewModel">

	<Grid RowSpacing="30"
		  Padding="25">
		<Grid.RowDefinitions>
			<RowDefinition Height="0.25*" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<Grid Grid.Row="0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="0.25*" />
				<ColumnDefinition Width="0.5*" />
				<ColumnDefinition Width="0.25*" />
			</Grid.ColumnDefinitions>

			<Button Grid.Column="0"
					Command="{Binding TapReturnCommand}"
					BackgroundColor="{StaticResource Orange}"
					Text="Back"
					FontSize="18"
					FontAttributes="Bold"
					TextColor="{StaticResource EggWhite}">
			</Button>

			<Label Grid.Column="1"
				   HorizontalOptions="Center"
				   VerticalOptions="Center"
				   Text="Recipe"
				   FontSize="30"
				   FontAttributes="Bold"
				   TextColor="{StaticResource Orange}" />
		</Grid>

		<Grid Grid.Row="1">
			<Label Grid.Column="1"
				   HorizontalOptions="Center"
				   VerticalOptions="Center"
				   Text="Recipe text"
				   FontSize="30"
				   FontAttributes="Bold"
				   TextColor="{StaticResource Gray600}" />
		</Grid>
	</Grid>
</ContentPage>